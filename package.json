{
  "name": "intlayer-vite-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start:editor": "npx intlayer-editor start --with 'vite dev'",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "25.5.0",
    "intlayer-editor": "latest",
    "svelte": "5.55.0",
    "svelte-check": "4.4.5",
    "typescript": "6.0.2",
    "vite": "^8.0.2",
    "vite-intlayer": "latest"
  },
  "dependencies": {
    "@intlayer/svelte-compiler": "latest",
    "intlayer": "latest",
    "svelte-intlayer": "latest",
    "svelte-spa-router": "^5.0.0"
  }
}
